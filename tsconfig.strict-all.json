{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strictNullChecks": true,
    "noImplicitAny": false
  },
  "include": [
    "vite-env.d.ts",
    "types/**/*.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "backend",
    "dist",
    "release-server",
    "electron/dist",
    "**/*.test.ts",
    "tests",
    "components/license/**",
    "components/settings/WarehouseManagement.tsx"
  ]
}
