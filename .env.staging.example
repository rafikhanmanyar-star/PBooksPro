# PBooks Pro — STAGING environment (copy to .env.staging, never commit)
# PostgreSQL database: pbooks_staging
# API listens on port 3001 so production (3000) can run on the same machine.

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/pbooks_staging
JWT_SECRET=change-me-staging-secret-at-least-16-chars
PORT=3001
NODE_ENV=production

# Client build (API mode — PostgreSQL via staging API)
VITE_LOCAL_ONLY=false
VITE_STAGING=true
VITE_API_URL=http://127.0.0.1:3001/api
VITE_WS_URL=http://127.0.0.1:3001

# GitHub publish for staging prereleases (optional for manual deploy)
# GH_TOKEN=ghp_xxxxxxxxxxxx
