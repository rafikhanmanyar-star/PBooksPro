# PBooks Pro — STAGING environment (copy to .env.staging, never commit)
# PostgreSQL database: pbooks_staging
# API listens on port 3001 so production (3000) can run on the same machine.

DATABASE_URL=postgresql://postgres:@127.0.0.1:5432/pBookspro_Staging
JWT_SECRET=change-me-staging-secret-at-least-16-chars
PORT=3001
NODE_ENV=production
# desktop = local API + Electron installers; cloud = hosted SaaS (hides in-app updates)
APP_EDITION=desktop
# Seed via: npm run db:seed:staging (do not set SEED_STAGING=1 here unless you also set ALLOW_STAGING_SEED_IN_PRODUCTION=true)

# Default org on empty staging DB: "test company" (tenant id test-company), user Rafi / Rafi1234
DISABLE_MFA_ENFORCEMENT=true
DISABLE_SUBSCRIPTION_ENFORCEMENT=true
VITE_DEFAULT_TENANT_ID=test-company

# Client build (API mode — PostgreSQL via staging API)
VITE_LOCAL_ONLY=false
VITE_STAGING=true
VITE_API_URL=http://127.0.0.1:3001/api/v1
VITE_WS_URL=http://127.0.0.1:3001

# Paddle Billing (sandbox)
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_ENV=sandbox
# VITE_PADDLE_CLIENT_TOKEN=
# VITE_PADDLE_ENV=sandbox

# Cloudflare R2 document storage (Architecture v2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=
# R2_ENDPOINT_URL=

# RBAC V2 — staging pilot (Data Scope ON; Approval Matrix OFF)
RBAC_V2_ROLE_MANAGEMENT=true
RBAC_V2_SOD=true
RBAC_V2_BREAK_GLASS=true
RBAC_V2_AUTHORIZATION_ENGINE=true
RBAC_V2_DATA_SCOPE=true
RBAC_V2_APPROVAL_MATRIX=false
VITE_RBAC_V2_ROLE_MANAGEMENT=true
VITE_RBAC_V2_BREAK_GLASS=true
VITE_RBAC_V2_DATA_SCOPE=true
VITE_RBAC_V2_APPROVAL_MATRIX=false

# GitHub publish for staging prereleases (optional for manual deploy)
# GH_TOKEN=ghp_xxxxxxxxxxxx
