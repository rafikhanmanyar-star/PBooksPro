# PBooks Pro — PRODUCTION environment (copy to .env.production, never commit)
# PostgreSQL database: pbookspro
# API listens on port 3000.

DATABASE_URL=postgresql://postgres:@127.0.0.1:5432/pbookspro
JWT_SECRET=change-me-production-secret-at-least-16-chars
PORT=3000
NODE_ENV=production
# desktop = local install; cloud = Render / hosted SaaS (set APP_EDITION=cloud there)
APP_EDITION=desktop
# TRUST_PROXY=true

# Client build (API mode — PostgreSQL via production API)
VITE_LOCAL_ONLY=false
VITE_API_URL=http://127.0.0.1:3000/api
VITE_WS_URL=http://127.0.0.1:3000

# Paddle Billing (backend — also set in backend/.env or merged deploy env)
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_ENV=live
# PAST_DUE_GRACE_DAYS=7
# ENABLE_SUBSCRIPTION_ENFORCEMENT=true
# ENABLE_BILLING_SCHEDULER=true

# Paddle checkout overlay (client build)
# VITE_PADDLE_CLIENT_TOKEN=
# VITE_PADDLE_ENV=live

# GitHub publish for production releases
# GH_TOKEN=ghp_xxxxxxxxxxxx
