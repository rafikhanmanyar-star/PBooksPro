    "legacy:prepare-local-db": "node tools/legacy/prepare-local-db.cjs",
    "legacy:migrate-sqlite-to-postgres": "node tools/legacy/sqlite-to-postgres-rk-builders.cjs",
    "legacy:migrate-sqlite-to-postgres:transactions": "node tools/legacy/sqlite-to-postgres-rk-builders.cjs --transactions-only",
    "legacy:repair-pg-categories": "node tools/legacy/repair-postgres-categories-from-sqlite.cjs",
    "legacy:migrate-from-cloud": "node tools/legacy/migrate-from-cloud.cjs",
    "legacy:dedupe-local-db": "node tools/legacy/dedupe-local-db.cjs",
    "legacy:copy-tenant-from-production": "node tools/legacy/copy-tenant-from-production.cjs",
    "clear-local-transactions": "npm run legacy:clear-local-transactions",
    "prepare-local-db": "npm run legacy:prepare-local-db",
    "migrate-from-cloud": "npm run legacy:migrate-from-cloud",
    "migrate:sqlite-to-postgres": "npm run legacy:migrate-sqlite-to-postgres",
    "migrate:sqlite-to-postgres:transactions": "npm run legacy:migrate-sqlite-to-postgres:transactions",
    "repair:pg-categories": "npm run legacy:repair-pg-categories",
