    "postinstall": "node scripts/rebuild-native.cjs",
    "repair:electron": "node scripts/repair-electron.cjs",
    "release:staging": "node scripts/release-staging.cjs",
    "release:production": "node scripts/release-production.cjs",
    "deploy:staging": "dotenv -e .env.staging -- node scripts/run-with-gh-token.cjs --require --env-file .env.staging -- npm run deploy:staging-inner",
    "deploy:staging-inner": "node scripts/assert-git-branch.cjs staging && npm run verify:staging-release:preflight && npm run rebuild:native && cross-env PBOOKS_BUMP_VERSION=1 node scripts/bump-package-patch.cjs && npm run build:backend && npm run verify:staging-release:backend && npm run db:migrate:staging && npm run db:seed:staging && cross-env PBOOKS_STAGE_API_SERVER=1 npm run electron:stage-api-server && npm run verify:staging-release:api-server && electron-builder --win nsis -c electron-builder-api-server-staging.yml --publish never && node scripts/clean-dist.cjs && cross-env VITE_LOCAL_ONLY=false VITE_ELECTRON_BUILD=true VITE_STAGING=true VITE_API_URL=http://127.0.0.1:3001/api VITE_WS_URL=http://127.0.0.1:3001 npm run build && npm run verify:staging-release:client && npm run verify:dist-bundle-integrity && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --publish always -c electron-builder-api-client-staging.yml && cross-env PBOOKS_RELEASE_API_SERVER_DIR=release-api-server-staging PBOOKS_API_SERVER_SETUP_PREFIX=PBooks-Pro-Staging-API-Server-Setup PBOOKS_API_SERVER_CHANNEL_YML=api-server-staging.yml node scripts/upload-api-server-to-github-release.cjs && node scripts/push-release-source-to-github.cjs",
    "deploy:production": "dotenv -e .env.production -- node scripts/run-with-gh-token.cjs --require --env-file .env.production -- npm run deploy:production-inner",
    "deploy:production-inner": "node scripts/assert-git-branch.cjs main && npm run rebuild:native && cross-env PBOOKS_BUMP_VERSION=1 node scripts/bump-package-patch.cjs && npm run build:backend && npm run db:migrate:production && npm run electron:stage-api-server && electron-builder --win nsis -c electron-builder-api-server.yml --publish never && node scripts/clean-dist.cjs && cross-env VITE_LOCAL_ONLY=false VITE_ELECTRON_BUILD=true VITE_STAGING=false VITE_API_URL=http://127.0.0.1:3000/api VITE_WS_URL=http://127.0.0.1:3000 npm run build && npm run verify:dist-bundle-integrity && electron-builder --win nsis -c electron-builder-api-client.yml --publish always && node scripts/upload-api-server-to-github-release.cjs && node scripts/push-release-source-to-github.cjs && node scripts/clean-old-github-releases.cjs --keep 3 --ignore-missing-token",
    "github:clean-releases": "dotenv -e .env -- node scripts/clean-old-github-releases.cjs",
    "github:backfill-staging-yml": "dotenv -e .env.staging -- node scripts/upload-staging-channel-yml.cjs",
    "smoke:design-system": "node scripts/smoke-test-design-system.mjs",
    "smoke:design-system:full": "node scripts/smoke-test-design-system.mjs --build",
    "audit:theme": "node scripts/audit-theme-compliance.mjs",
    "audit:theme:strict": "node scripts/audit-theme-compliance.mjs --fail-on-warn",
    "verify:financial-engine": "node scripts/verify-financial-engine.mjs",
    "verify:sql-guard": "node scripts/check-services-sql-guard.mjs",
    "typecheck:strict-financial": "tsc -p tsconfig.strict-financial.json --noEmit",
    "typecheck:c2": "tsc -p tsconfig.strict-all.json --noEmit",
    "verify:equity-ledger": "node scripts/verify-equity-ledger.mjs",
    "test:date-only": "tsx tests/dateOnlySerialization.test.ts",
    "verify:api-client:phase6": "powershell -ExecutionPolicy Bypass -File scripts/verify-api-client-phase6.ps1",
    "verify:realtime:track-e": "powershell -ExecutionPolicy Bypass -File scripts/verify-realtime-track-e.ps1",
    "verify:staging-release": "powershell -ExecutionPolicy Bypass -File scripts/verify-staging-release.ps1",
    "verify:staging-release:preflight": "powershell -ExecutionPolicy Bypass -File scripts/verify-staging-release.ps1 -Step Preflight",
    "verify:staging-release:backend": "powershell -ExecutionPolicy Bypass -File scripts/verify-staging-release.ps1 -Step AfterBackend",
    "verify:staging-release:api-server": "powershell -ExecutionPolicy Bypass -File scripts/verify-staging-release.ps1 -Step AfterApiServer",
    "verify:staging-release:client": "powershell -ExecutionPolicy Bypass -File scripts/verify-staging-release.ps1 -Step AfterClient",
    "clean:dist": "node scripts/clean-dist.cjs",
    "verify:dist-bundle-integrity": "node scripts/verify-dist-bundle-integrity.mjs",
    "verify:track-e2": "powershell -ExecutionPolicy Bypass -File scripts/verify-realtime-track-e.ps1",
    "verify:track-f-p4": "node scripts/verify-track-f-p4.mjs",
    "test:balance-sheet": "tsx tests/balanceSheetEngine.test.ts",
    "test:cash-flow": "tsx tests/cashFlowJournalCore.test.ts",
    "test:trial-balance": "tsx tests/trialBalanceCore.test.ts",
    "test:ledger-reconciliation": "tsx tests/ledgerReconciliation.test.ts",
    "test:financial-reconciliation": "tsx tests/financialReconciliationEngine.test.ts",
    "test:version-check": "tsx tests/versionCheck.test.ts",
    "test:amount-input": "tsx tests/AmountInput.test.tsx",
    "dev:backend": "npm run dev --prefix backend",
    "start:backend": "npm run start --prefix backend",
    "build:backend": "npm install --prefix backend --include=dev && npm run build --prefix backend",
    "build:backend:render": "npm install --prefix backend --include=dev && npm run build --prefix backend",
    "test:backend": "npm test --prefix backend",
    "test:perf:dashboard": "npm run test:perf:dashboard --prefix backend",
    "db:migrate:lan": "dotenv -e .env -- npm run migrate --prefix backend",
    "db:migrate:staging": "dotenv -e .env.staging -- npm run migrate --prefix backend",
    "db:seed:staging": "dotenv -e .env.staging -- tsx backend/src/scripts/seedStagingDefaults.ts",
    "list:production-cloud-credentials": "node scripts/list-production-cloud-credentials.mjs",
    "db:migrate:production": "dotenv -e .env.production -- npm run migrate --prefix backend",
    "start:backend:staging": "dotenv -e .env.staging -- npm run start --prefix backend",
    "start:backend:production": "dotenv -e .env.production -- npm run start --prefix backend",
    "dev:backend:staging": "dotenv -e .env.staging -- npm run dev --prefix backend",
    "dev:backend:production": "dotenv -e .env.production -- npm run dev --prefix backend",
    "db:backfill-payroll-ledger": "dotenv -e .env -- npm run backfill-payroll-ledger --prefix backend --",
    "db:backfill-transaction-journal": "dotenv -e .env -- npm run backfill-transaction-journal --prefix backend --",
    "db:backfill-journal-dimensions": "dotenv -e .env -- npm run backfill-journal-dimensions --prefix backend --",
    "db:backfill-journal-dimensions:staging": "dotenv -e .env.staging -- npm run backfill-journal-dimensions --prefix backend --",
    "db:backfill-journal-dimensions:production": "dotenv -e .env.production -- npm run backfill-journal-dimensions --prefix backend --",
    "db:backfill-documents-metadata": "dotenv -e .env -- npm run backfill-documents-metadata --prefix backend --",
    "db:backfill-documents-metadata:staging": "dotenv -e .env.staging -- npm run backfill-documents-metadata --prefix backend --",
    "db:backfill-documents-metadata:production": "dotenv -e .env.production -- npm run backfill-documents-metadata --prefix backend --",
    "reset-pm-cycle": "dotenv -e .env -- npm run reset-pm-cycle --prefix backend --"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "dayjs": "^1.11.20",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "react-window": "^2.2.3",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@google/genai": "^1.29.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^7.4.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.25.12",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.555.0",
    "pg": "^8.19.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-to-print": "^3.2.0",
    "recharts": "^3.3.0",
    "sharp": "^0.34.5",
    "sql.js": "^1.13.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2",
    "vite": "^7.2.4",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.pbookspro.app",
    "productName": "PBooks Pro",
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/assets/sql-asm*",
      "!dist/assets/sql-wasm*",
      "!dist/assets/sqljs-*",
      "!dist/assets/worker.sql-*",
      "!dist/**/*.map",
      "electron/main.cjs",
      "electron/preload.cjs",
      "electron/sqliteBridge.cjs",
      "electron/stability.cjs",
      "electron/schemaValidator.cjs",
      "electron/schemaVersion.json",
      "electron/migrations/**/*.cjs",
      "electron/companyManager.cjs",
      "electron/emailAuthMigration.cjs",
      "electron/spellChecker.cjs",
      "electron/updaterErrorUtils.cjs",
      "electron/githubReleaseUtils.cjs",
      "electron/stagingUpdateFeed.cjs",
      "electron/schema.sql",
      "electron/assets/**/*",
      "package.json",
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**",
      "node_modules/electron-updater/**",
      "node_modules/builder-util-runtime/**",
      "node_modules/debug/**",
      "node_modules/ms/**",
      "node_modules/supports-color/**",
      "node_modules/has-flag/**",
      "node_modules/fs-extra/**",
      "node_modules/graceful-fs/**",
      "node_modules/jsonfile/**",
      "node_modules/universalify/**",
      "node_modules/js-yaml/**",
      "node_modules/lazy-val/**",
      "node_modules/lodash.escaperegexp/**",
      "node_modules/lodash.isequal/**",
      "node_modules/sax/**",
      "node_modules/semver/**",
      "node_modules/tiny-typed-emitter/**",
      "!node_modules/**/{test,tests,__tests__,docs,doc,example,examples}/**",
      "!node_modules/**/*.{md,ts,map}"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/electron-updater/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PBooks Pro",
      "artifactName": "PBooks-Pro-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ]
  }
}
