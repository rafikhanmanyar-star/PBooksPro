{
  "name": "pbooks-pro",
  "private": true,
  "version": "1.2.235",
  "description": "PBooks Pro - Finance and Project Management Application",
  "author": "PBooks Pro",
  "repository": {
    "type": "git",
    "url": "https://github.com/rafikhanmanyar-star/PBooksPro"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:api": "cross-env VITE_LOCAL_ONLY=false vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:extract-schema": "node scripts/extract-schema.cjs",
    "electron": "npm run electron:local",
    "electron:dev": "npm run rebuild:native && cross-env VITE_LOCAL_ONLY=true VITE_ELECTRON_BUILD=true vite build && electron . --enable-logging",
    "electron:pack": "npm run electron:extract-schema && cross-env VITE_ELECTRON_BUILD=true npm run build && electron-builder --dir",
    "electron:local": "npm run rebuild:native && npm run electron:extract-schema && cross-env VITE_LOCAL_ONLY=true VITE_ELECTRON_BUILD=true npm run build && electron . --enable-logging",
    "electron:installer": "npm run rebuild:native && npm run electron:extract-schema && cross-env VITE_LOCAL_ONLY=true VITE_ELECTRON_BUILD=true npm run build && electron-builder --win nsis",
    "electron:build:api-client": "npm run rebuild:native && npm run electron:extract-schema && cross-env VITE_LOCAL_ONLY=false VITE_ELECTRON_BUILD=true npm run build",
    "electron:installer:api": "npm run electron:build:api-client && electron-builder --win nsis -c electron-builder-api-client.yml",
    "electron:stage-api-server": "node scripts/stage-electron-api-server.cjs",
    "electron:installer:api-server": "npm run electron:stage-api-server && electron-builder --win nsis -c electron-builder-api-server.yml --publish never",
    "package:server": "powershell -ExecutionPolicy Bypass -File scripts/package-server.ps1",
    "clear-local-transactions": "node tools/clear-local-transactions.cjs",
    "dedupe-local-db": "node scripts/dedupe-local-db.cjs",
    "test:local-only": "powershell -ExecutionPolicy Bypass -File test-local-only.ps1",
    "test:local-only:watch": "powershell -ExecutionPolicy Bypass -File test-local-only.ps1 -BackendWatch",
    "prepare-local-db": "node scripts/prepare-local-db.cjs",
    "migrate-from-cloud": "node scripts/migrate-from-cloud.cjs",
    "migrate:sqlite-to-postgres": "node scripts/sqlite-to-postgres-rk-builders.cjs",
    "migrate:sqlite-to-postgres:transactions": "node scripts/sqlite-to-postgres-rk-builders.cjs --transactions-only",
    "repair:pg-categories": "node scripts/repair-postgres-categories-from-sqlite.cjs",
    "repair:profit-distribution-categories": "node scripts/repair-profit-distribution-categories.cjs",
    "repair:profit-distribution-categories:pg": "dotenv -e .env -- node scripts/repair-profit-distribution-categories.cjs --pg",
    "seed:rk-builders-rafi": "node scripts/seed-rk-builders-rafi.cjs",
    "migrate-pbookspro-to-rkbuilders": "node scripts/migrate-pbookspro-to-rkbuilders.cjs",
    "copy-tenant-from-production": "node scripts/copy-tenant-from-production.cjs",
    "export-tenant-to-excel": "node scripts/export-tenant-to-excel.cjs",
    "delete-rkbuilders-rental-data": "node scripts/delete-rkbuilders-rental-agreements-and-invoices.cjs",
    "delete-project-agreement": "node scripts/delete-project-agreement-by-number.cjs",
    "insert-pg-dp-invoice": "dotenv -e .env -- node scripts/insert-pg-missing-dp-invoice.cjs",
    "delete-pg-dp-invoice": "dotenv -e .env -- node scripts/insert-pg-missing-dp-invoice.cjs --delete",
    "sync-db-to-blob": "node scripts/sync-db-to-blob.cjs",
    "postinstall": "node scripts/rebuild-native.cjs",
    "rebuild:native": "node scripts/rebuild-native.cjs",
    "deploy:staging": "dotenv -e .env -- npm run deploy:staging-inner",
    "deploy:staging-inner": "npm run rebuild:native && npm version patch --no-git-tag-version && npm run electron:extract-schema && cross-env VITE_LOCAL_ONLY=true VITE_ELECTRON_BUILD=true VITE_STAGING=true npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --publish always -c electron-builder-staging.yml",
    "deploy:production": "dotenv -e .env -- npm run deploy:production-inner",
    "deploy:production-inner": "npm run rebuild:native && npm version patch --no-git-tag-version && npm run electron:extract-schema && npm run build:backend && npm run electron:stage-api-server && electron-builder --win nsis -c electron-builder-api-server.yml --publish never && cross-env VITE_LOCAL_ONLY=false VITE_ELECTRON_BUILD=true npm run build && electron-builder --win nsis -c electron-builder-api-client.yml --publish always && node scripts/upload-api-server-to-github-release.cjs && node scripts/push-release-source-to-github.cjs && node scripts/clean-old-github-releases.cjs --keep 3 --ignore-missing-token",
    "github:clean-releases": "dotenv -e .env -- node scripts/clean-old-github-releases.cjs",
    "smoke:design-system": "node scripts/smoke-test-design-system.mjs",
    "smoke:design-system:full": "node scripts/smoke-test-design-system.mjs --build",
    "verify:financial-engine": "node scripts/verify-financial-engine.mjs",
    "verify:equity-ledger": "node scripts/verify-equity-ledger.mjs",
    "test:date-only": "tsx tests/dateOnlySerialization.test.ts",
    "test:balance-sheet": "tsx tests/balanceSheetEngine.test.ts",
    "test:cash-flow": "tsx tests/cashFlowEngine.test.ts",
    "dev:backend": "npm run dev --prefix backend",
    "start:backend": "npm run start --prefix backend",
    "build:backend": "npm run build --prefix backend",
    "db:migrate:lan": "dotenv -e .env -- npm run migrate --prefix backend",
    "reset-pm-cycle": "dotenv -e .env -- npm run reset-pm-cycle --prefix backend --"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "better-sqlite3": "^12.6.2",
    "dayjs": "^1.11.20",
    "electron-updater": "^6.8.3",
    "react-window": "^2.2.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@google/genai": "^1.29.0",
    "@types/node": "^22.14.0",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^7.4.2",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.25.12",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.555.0",
    "pg": "^8.19.0",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-to-print": "^3.2.0",
    "recharts": "^3.3.0",
    "sql.js": "^1.13.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2",
    "vite": "^7.2.4",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.pbookspro.app",
    "productName": "PBooks Pro",
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/assets/sql-asm*",
      "!dist/assets/sql-wasm*",
      "!dist/assets/sqljs-*",
      "!dist/assets/worker.sql-*",
      "!dist/**/*.map",
      "electron/main.cjs",
      "electron/preload.cjs",
      "electron/sqliteBridge.cjs",
      "electron/stability.cjs",
      "electron/schemaValidator.cjs",
      "electron/schemaVersion.json",
      "electron/migrations/**/*.cjs",
      "electron/companyManager.cjs",
      "electron/spellChecker.cjs",
      "electron/updaterErrorUtils.cjs",
      "electron/schema.sql",
      "electron/assets/**/*",
      "package.json",
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**",
      "node_modules/electron-updater/**",
      "node_modules/builder-util-runtime/**",
      "node_modules/debug/**",
      "node_modules/ms/**",
      "node_modules/supports-color/**",
      "node_modules/has-flag/**",
      "node_modules/fs-extra/**",
      "node_modules/graceful-fs/**",
      "node_modules/jsonfile/**",
      "node_modules/universalify/**",
      "node_modules/js-yaml/**",
      "node_modules/lazy-val/**",
      "node_modules/lodash.escaperegexp/**",
      "node_modules/lodash.isequal/**",
      "node_modules/sax/**",
      "node_modules/semver/**",
      "node_modules/tiny-typed-emitter/**",
      "!node_modules/**/{test,tests,__tests__,docs,doc,example,examples}/**",
      "!node_modules/**/*.{md,ts,map}"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/electron-updater/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PBooks Pro",
      "artifactName": "PBooks-Pro-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ]
  }
}
