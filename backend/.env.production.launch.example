# PBooksPro API — Production launch flags
# Merge into your production .env (see doc/PHASE2_STAGING_CHECKLIST.md)

NODE_ENV=production
PORT=3000
TRUST_PROXY=true

# Website conversion funnels
ALLOW_TRIAL_SIGNUP=true
TRIAL_SIGNUP_APP_URL=https://app.pbookspro.com

MARKETING_LEADS_ENABLED=true
MARKETING_SITE_URL=https://www.pbookspro.com
MARKETING_CHECKLIST_URL=https://www.pbookspro.com/assets/checklists/property-management-accounting-checklist.html
MARKETING_LEAD_MAGNET_URL=https://www.pbookspro.com/blog/property-management-accounting-guide.html

SUPPORT_TICKETS_ENABLED=true

DEMO_BOOKING_ENABLED=true
DEMO_BOOKING_EMAIL_ENABLED=true
DEMO_BOOKING_ADMIN_EMAIL=support@pbookspro.com
DEMO_BOOKING_EMAIL_FROM=hello@pbookspro.com
DEMO_BOOKING_SUCCESS_URL=https://www.pbookspro.com/demo-success.html

# Email automation
EMAIL_AUTOMATION_ENABLED=true
EMAIL_AUTOMATION_SEND_ENABLED=true
EMAIL_AUTOMATION_SCHEDULER=true
EMAIL_AUTOMATION_INTERVAL_MS=300000
EMAIL_AUTOMATION_PUBLIC_BASE_URL=https://app.pbookspro.com
EMAIL_AUTOMATION_APP_URL=https://app.pbookspro.com
EMAIL_AUTOMATION_BILLING_URL=https://app.pbookspro.com/settings?tab=billing
EMAIL_AUTOMATION_EMAIL_FROM=hello@pbookspro.com
EMAIL_AUTOMATION_UNSUBSCRIBE_SECRET=change-me-long-random-unsubscribe-secret

MARKETING_EMAIL_SCHEDULER=true
MARKETING_EMAIL_SEND_ENABLED=true
MARKETING_EMAIL_FROM=hello@pbookspro.com

# SMTP — configure before launch
# MARKETING_SMTP_HOST=smtp.example.com
# MARKETING_SMTP_PORT=587
# EMAIL_AUTOMATION_SMTP_HOST=smtp.example.com
# EMAIL_AUTOMATION_SMTP_PORT=587

# Public live demo (website demo-login.html → app.pbookspro.com)
# DEMO_ENVIRONMENT_ENABLED=true
# DEMO_PUBLIC_LOGIN_ENABLED=true
# DEMO_TRIAL_DAYS=7
# ALLOW_DEMO_SEED_IN_PRODUCTION=true
# DEMO_USER_PASSWORD=change-me-strong-demo-password
# DEMO_AUTO_RESET=true
# DEMO_RESET_HOUR_UTC=3
# DEMO_RESET_ON_STARTUP=true
# DEMO_RESET_SECRET=long-random-cron-secret
# DEMO_READ_ONLY=false
# DEMO_SEED_MASTER=true

# Website analytics (set before npm run build:website)
# PBBOOKS_GTM_ID=GTM-XXXXXXX
# PBBOOKS_GA4_ID=G-XXXXXXXXXX
# PBBOOKS_META_PIXEL_ID=
# PBBOOKS_LINKEDIN_PARTNER_ID=
