# PBooksPro API — local dev with Cloudflare website
# Copy relevant lines into backend/.env, then rebuild + restart the API.

PORT=3000
NODE_ENV=development

# Required for website forms on www.pbookspro.com (via tunnel or deployed API)
ALLOW_TRIAL_SIGNUP=true
TRIAL_SIGNUP_APP_URL=https://app.pbookspro.com

MARKETING_LEADS_ENABLED=true
MARKETING_SITE_URL=https://www.pbookspro.com
MARKETING_CHECKLIST_URL=https://www.pbookspro.com/assets/checklists/property-management-accounting-checklist.html
MARKETING_LEAD_MAGNET_URL=https://www.pbookspro.com/blog/property-management-accounting-guide.html

SUPPORT_TICKETS_ENABLED=true

DEMO_BOOKING_ENABLED=true
DEMO_BOOKING_EMAIL_ENABLED=false
DEMO_BOOKING_SUCCESS_URL=https://www.pbookspro.com/demo-success.html

# Optional — email automation (needs SMTP)
# EMAIL_AUTOMATION_ENABLED=true
# MARKETING_EMAIL_SEND_ENABLED=false
