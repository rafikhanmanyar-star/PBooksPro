# PBooks Pro API Server — loads this file (or process env). All clients talk to PostgreSQL only via this API.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pbooks
JWT_SECRET=change-me-to-a-long-random-secret-at-least-16-chars
PORT=3000
NODE_ENV=development
# After pulling backend fixes, rebuild and restart: npm run build:backend && npm run start:backend
# Create default tenant, users, and system accounts (only when SEED_DEV_USER=1 or NODE_ENV=development)
SEED_DEV_USER=1
DEV_ADMIN_PASSWORD=admin
# Optional second dev user (created if missing)
DEV_RAFI_PASSWORD=Rafi123
