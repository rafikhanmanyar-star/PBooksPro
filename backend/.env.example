# PBooks Pro API Server — loads this file (or process env). All clients talk to PostgreSQL only via this API.
# Production DB: pbookspro (see ../.env.production.example)
# Staging DB:     pbooks_staging (see ../.env.staging.example, default PORT=3001)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pbooks
JWT_SECRET=change-me-to-a-long-random-secret-at-least-16-chars
PORT=3000
# Set when TLS terminates at nginx/Caddy in front of this service (see docs/lan-tls-deployment.md)
# TRUST_PROXY=true
NODE_ENV=development
# Deployment edition: desktop (local install) | cloud (hosted SaaS on Render, etc.)
APP_EDITION=desktop
# After pulling backend fixes, rebuild and restart: npm run build:backend && npm run start:backend
# Create default tenant, users, and system accounts (only when SEED_DEV_USER=1 or NODE_ENV=development)
SEED_DEV_USER=1
# Automated PostgreSQL backups (requires pg_dump on PATH; localhost or ENABLE_DB_BACKUP_RESTORE=true)
# ENABLE_BACKUP_SCHEDULER=true
# BACKUP_STORAGE_PATH=./backups/pg
# BACKUP_ENCRYPTION_KEY=long-random-secret-for-file-encryption
# BACKUP_STORAGE_MASTER_KEY=long-random-secret-for-credential-encryption
# Scheduled backups encrypt at rest (PBKENC1) when backup_security_settings.encrypt_at_rest=true
# DR_AUTO_VERIFY=true
# Disaster recovery email alerts (optional SMTP)
# DR_SMTP_HOST=smtp.example.com
# DR_SMTP_PORT=587
# DR_SMTP_USER=
# DR_SMTP_PASS=
# DR_SMTP_SECURE=false
# DR_ALERT_EMAIL_FROM=dr-alerts@example.com

# Referral program
# REFERRAL_SIGNUP_BASE_URL=https://app.pbookspro.com
# REFERRAL_SMTP_HOST=
# REFERRAL_SMTP_PORT=587
# REFERRAL_EMAIL_FROM=hello@pbookspro.com

# Paddle subscription billing
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_ENV=sandbox
# PADDLE_PRICE_PROFESSIONAL_MONTHLY=pri_xxx
# PADDLE_PRICE_PROFESSIONAL_ANNUAL=pri_xxx
# PADDLE_PRICE_ENTERPRISE_MONTHLY=pri_xxx
# PADDLE_PRICE_ENTERPRISE_ANNUAL=pri_xxx
# PADDLE_PRICE_STARTER_MONTHLY=pri_xxx
# PADDLE_PRICE_STARTER_ANNUAL=pri_xxx
# Days to allow access after payment failure before locking features (default 7)
# PAST_DUE_GRACE_DAYS=7
# Background maintenance: trials, grace expiry, pending downgrades, webhook retries
# ENABLE_BILLING_SCHEDULER=true
# BILLING_SCHEDULER_INTERVAL_MS=900000
# Require webhook HMAC even when PADDLE_API_KEY is unset (recommended in production)
# REQUIRE_PADDLE_WEBHOOK_SECRET=true
# Enterprise license enforcement (server-side; cannot be bypassed from client)
# Enabled automatically when NODE_ENV=production, or set explicitly:
# ENABLE_SUBSCRIPTION_ENFORCEMENT=true
# DISABLE_SUBSCRIPTION_ENFORCEMENT=true
# Skip MFA at login for staging/dev (Admin still uses MFA in production when unset)
# DISABLE_MFA_ENFORCEMENT=true
DEV_ADMIN_PASSWORD=admin
# Optional second dev user (created if missing)
DEV_RAFI_PASSWORD=Rafi1234

# Public live demo environment (isolated tenant pbooks-demo)
# DEMO_ENVIRONMENT_ENABLED=true
# DEMO_PUBLIC_LOGIN_ENABLED=true
# DEMO_USER_PASSWORD=Demo@2024!
# DEMO_AUTO_RESET=true
# DEMO_RESET_HOUR_UTC=3
# DEMO_RESET_ON_STARTUP=true
# DEMO_RESET_SECRET=long-random-cron-secret
# DEMO_READ_ONLY=false
# DEMO_SEED_MASTER=true
# ALLOW_DEMO_SEED_IN_PRODUCTION=true

# Demo booking (website demo.html → PostgreSQL + instant emails)
# DEMO_BOOKING_ENABLED=true
# DEMO_BOOKING_EMAIL_ENABLED=true
# DEMO_BOOKING_ADMIN_EMAIL=support@pbookspro.com
# DEMO_BOOKING_EMAIL_FROM=hello@pbookspro.com
# DEMO_BOOKING_SUCCESS_URL=https://www.pbookspro.com
# DEMO_BOOKING_CALENDLY_URL=https://calendly.com/your-team/pbookspro-demo
# MARKETING_SITE_URL=https://www.pbookspro.com

# Website analytics IDs are configured in website/js/analytics-config.js (GTM, GA4, Meta, LinkedIn).
# See doc/ANALYTICS.md for GTM trigger mapping and event taxonomy.

# Free trial self-service signup (website → tenant + 14-day trial + onboarding)
# ALLOW_TRIAL_SIGNUP=true
# TRIAL_SIGNUP_APP_URL=https://app.pbookspro.com

# Marketing lead funnel (website forms → PostgreSQL → CRM export)
# MARKETING_LEADS_ENABLED=true
# MARKETING_CHECKLIST_URL=https://www.pbookspro.com/assets/checklists/property-management-accounting-checklist.html
# MARKETING_CRM_EXPORT_SECRET=long-random-export-secret
# MARKETING_EMAIL_SCHEDULER=true
# MARKETING_EMAIL_SEND_ENABLED=true
# MARKETING_SMTP_HOST=smtp.example.com
# MARKETING_SMTP_PORT=587
# MARKETING_SMTP_USER=
# MARKETING_SMTP_PASS=
# MARKETING_EMAIL_FROM=hello@pbookspro.com
# MARKETING_LEAD_MAGNET_URL=https://www.pbookspro.com/blog/property-management-accounting-guide.html
# See doc/MARKETING_EMAIL_WORKFLOWS.md for demo, trial, and newsletter automation.

# Support center tickets (website forms → PostgreSQL)
# SUPPORT_TICKETS_ENABLED=true

# Customer lifecycle email automation (trial drip, billing, campaigns)
# EMAIL_AUTOMATION_ENABLED=true
# EMAIL_AUTOMATION_SEND_ENABLED=true
# EMAIL_AUTOMATION_SCHEDULER=true
# EMAIL_AUTOMATION_INTERVAL_MS=300000
# EMAIL_AUTOMATION_SMTP_HOST=smtp.example.com
# EMAIL_AUTOMATION_SMTP_PORT=587
# EMAIL_AUTOMATION_SMTP_USER=
# EMAIL_AUTOMATION_SMTP_PASS=
# EMAIL_AUTOMATION_EMAIL_FROM=hello@pbookspro.com
# EMAIL_AUTOMATION_PUBLIC_BASE_URL=https://app.pbookspro.com
# EMAIL_AUTOMATION_APP_URL=https://app.pbookspro.com
# EMAIL_AUTOMATION_BILLING_URL=https://app.pbookspro.com/settings?tab=billing
# EMAIL_AUTOMATION_UNSUBSCRIBE_SECRET=long-random-unsubscribe-secret

# Production monitoring (events, alerts, health checks)
# MONITORING_ENABLED=true
# MONITORING_SCHEDULER=true
# MONITORING_HEALTH_INTERVAL_MS=300000
# MONITORING_SLOW_REQUEST_MS=3000
# SENTRY_DSN=
# APPLICATIONINSIGHTS_CONNECTION_STRING=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=pbooks-backend
