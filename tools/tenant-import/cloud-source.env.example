# Cloud production PostgreSQL (Render external URL).
# Copy to one of:
#   - Same folder as PBooksPro-TenantImport.exe  →  cloud-source.env
#   - %APPDATA%\pbooks-pro\tenant-import\cloud-source.env
#
# The tenant import tool reads SOURCE_DATABASE_URL from this file so you are not prompted each run.

SOURCE_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
