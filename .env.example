# PBooks Pro - Local DB Only
# This project runs entirely offline with local SQLite. No cloud API or cloud DB.

# ---------------------------------------------------------------------------
# Run the app locally (Electron + local SQLite, no server required):
#   npm run test:local-only
# Or build and launch in one step:
#   npm run electron:local

# ---------------------------------------------------------------------------

# Local-only mode: `true` = SQLite + Electron (default). Set to `false` for LAN + API server (PostgreSQL).
VITE_LOCAL_ONLY=true
# Example when using local backend: VITE_LOCAL_ONLY=false and:
# VITE_API_URL=http://127.0.0.1:3000/api

# LAN / API (when VITE_LOCAL_ONLY=false): backend env is loaded separately; for `npm run db:migrate:lan` use root `.env` with:
# DATABASE_URL=postgresql://user:password@localhost:5432/pbooks
# JWT_SECRET=your-long-random-secret-string
# SEED_DEV_USER=1
# NODE_ENV=development
#
# Public self-service: POST /api/auth/register-tenant (creates tenant + admin user + chart of accounts).
# Set in **backend/.env** (the file the API server loads), not only in this example file. `.env.example` is never loaded at runtime.
# Rate-limited (5 / 15 min per IP).
# ALLOW_SELF_SIGNUP=true

# Local API (only used if running with optional local server via test:local)
# VITE_API_URL=http://localhost:3000/api

# WebSocket server URL (optional, not used in local-only mode)
# VITE_WS_URL=ws://localhost:3000

# Staging environment flag (used in build scripts)
# VITE_STAGING=true

# Electron build flag (set automatically by build scripts)
# VITE_ELECTRON_BUILD=true

# Base path for Vite (defaults to './' for Electron, '/' for web)
# VITE_BASE=./

# Electron load URL (for development, overrides default file:// path)
# ELECTRON_LOAD_URL=http://localhost:5174

# ---------------------------------------------------------------------------
# Publish installers to GitHub Releases (npm run deploy:staging / deploy:production):
#   Set GH_TOKEN or GITHUB_TOKEN to a GitHub personal access token with repo scope.
#   Add it below (or in your shell). Deploy scripts load .env from project root.
# GH_TOKEN=ghp_xxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Copy tenant from production to local DB (scripts/copy-tenant-from-production.cjs):
#   Set PG_URL to your production PostgreSQL connection string, then run:
#   npm run copy-tenant-from-production
#   npm run copy-tenant-from-production -- --tenant tenant_1767873389330_fce675e2
DATABASE_URL=postgresql://postgres:cTI123@127.0.0.1:5432/pbookspro
ALLOW_SELF_SIGNUP=true

# ---------------------------------------------------------------------------
# SQLite → PostgreSQL import / category repair (scripts/sqlite-to-postgres-rk-builders.cjs, repair-postgres-categories-from-sqlite.cjs):
#   Default path is baked into both scripts: F:\DB Backup pbookspro\rkbuilders_14_3_2026_backup_20260329_142110
#   Override with --sqlite "PATH" or set:
# SQLITE_BACKUP_PATH=F:/DB Backup pbookspro/rkbuilders_14_3_2026_backup_20260329_142110
# Target PostgreSQL tenant id (optional; default rk-builders-284d6d in scripts):
# PG_TARGET_TENANT_ID=rk-builders-284d6d